      ]
    },
    "Issue Alert → Telegram": { "main": [[{ "node": "Heartbeat to Bot", "type": "main", "index": 0 }]] },
    "Send Daily Summary": { "main": [[{ "node": "Heartbeat to Bot", "type": "main", "index": 0 }]] },
    "Error Trigger": { "main": [[{ "node": "Error → Telegram", "type": "main", "index": 0 }]] }
  },
  "settings": { "executionOrder": "v1" },
