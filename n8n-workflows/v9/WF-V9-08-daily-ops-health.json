    "Get Campaign Metrics": { "main": [[{ "node": "Build Daily Summary", "type": "main", "index": 0 }]] },
    "Get Today Submissions": { "main": [[{ "node": "Build Daily Summary", "type": "main", "index": 0 }]] },
    "Get Dead Letters": { "main": [[{ "node": "Build Daily Summary", "type": "main", "index": 0 }]] },
    "Get Open Tickets": { "main": [[{ "node": "Build Daily Summary", "type": "main", "index": 0 }]] },
    "Build Daily Summary": {
      "main": [[
        { "node": "Send Daily Summary", "type": "main", "index": 0 },
