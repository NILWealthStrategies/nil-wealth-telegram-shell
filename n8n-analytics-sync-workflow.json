            "index": 0
          }
        ]
      ]
    },
    "Combine Event with Lead": {
      "main": [
        [
          {
            "node": "Log Analytics Metric",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Log Analytics Metric": {
      "main": [
        [
          {
            "node": "Update Sequence Status",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Update Sequence Status": {
      "main": [
        [
          {
            "node": "Loop Back",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Loop Back": {
      "main": [
        [
          {
            "node": "Loop Over Events",
            "type": "main",
            "index": 0
          }
        ]
      ]
