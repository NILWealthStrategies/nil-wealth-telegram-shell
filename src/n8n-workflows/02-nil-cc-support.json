{
  "name": "nil-cc-support",
  "nodes": [
    {
      "parameters": {
        "path": "nil-cc-support",
        "responseMode": "onReceived",
        "responseData": "successResponse"
      },
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [100, 300],
      "webhookId": ""
    },
    {
      "parameters": {
        "url": "={{ $env.CC_SUPPORT_WEBHOOK_URL || $env.CC_SUPPORT_INTERNAL_WEBHOOK || 'https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK' }}",
        "method": "POST",
        "sendBody": true,
        "contentType": "application/json",
        "body": "{\n  \"text\": \"📋 Conversation Copied to Support\",\n  \"blocks\": [\n    {\n      \"type\": \"section\",\n      \"text\": {\n        \"type\": \"mrkdwn\",\n        \"text\": \"*Conversation CC*\\nFrom: {{ $node.Webhook.json.from_email }}\\nEmail: {{ $node.Webhook.json.email }}\\nConversation ID: {{ $node.Webhook.json.conversation_id }}\"\n      }\n    },\n    {\n      \"type\": \"section\",\n      \"text\": {\n        \"type\": \"mrkdwn\",\n        \"text\": \"Message:\\n{{ $node.Webhook.json.message }}\"\n      }\n    }\n  ]\n}"
      },
      "name": "Post to Support Channel",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [300, 300]
    },
    {
      "parameters": {
        "jsCode": "return {\n  ok: true,\n  copied_at: new Date().toISOString(),\n  conversation_id: $node.Webhook.json.conversation_id,\n  email: $node.Webhook.json.email\n};"
      },
      "name": "Return Success",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [500, 300]
    }
  ],
  "connections": {
    "Webhook": {
      "main": [
        [
          {
            "node": "Post to Support Channel",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Post to Support Channel": {
      "main": [
        [
          {
            "node": "Return Success",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
